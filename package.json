{
  "name": "browser-photoshop-editor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.5.2",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "predev": "npm run check:node",
    "dev": "next dev",
    "prebuild": "npm run check:node",
    "build": "next build --webpack && node scripts/normalize-next-env.mjs",
    "build:static": "npm run check:capabilities && npm run check:architecture && node scripts/build-static-export.mjs",
    "start": "next start",
    "preverify": "npm run check:node",
    "check:node": "node scripts/ensure-node-22.mjs",
    "doctor": "node scripts/doctor.mjs",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "typecheck": "node scripts/typecheck.mjs",
    "check:source-hygiene": "node scripts/check-source-hygiene.mjs",
    "test:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:smoke:local": "playwright test --config=playwright.smoke.config.ts",
    "test:smoke:ci": "playwright test --config=playwright.smoke.config.ts --workers=1",
    "test:static-export:smoke": "playwright test --config=playwright.static.config.ts",
    "test:full": "playwright test --config=playwright.config.ts --grep-invert @visual",
    "test:full:shard": "playwright test --config=playwright.config.ts --grep-invert @visual --shard",
    "test:dev": "playwright test --config=playwright.dev.config.ts",
    "test:repeat:critical": "playwright test --config=playwright.repeat.config.ts",
    "test:visual": "playwright test --grep @visual",
    "test:accessibility": "playwright test tests/accessibility-rendered.spec.ts --config=playwright.config.ts",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:coverage:changed": "npm run test:unit:coverage && node scripts/check-changed-coverage.mjs",
    "check:capabilities": "node scripts/check-capabilities.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:unused-scaffolds": "node scripts/check-unused-scaffolds.mjs",
    "select:pr-tests": "node scripts/select-pr-tests.mjs",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "verify:quality": "npm run lint:strict && npm run typecheck && npm run test:unit && npm run check:source-hygiene && npm run check:capabilities && npm run check:architecture && npm run check:unused-scaffolds && npm run build && npm run analyze:bundle && npm run test:smoke",
    "verify": "npm run verify:quality"
  },
  "dependencies": {
    "@abasb75/jpeg2000-decoder": "^2.5.4-f",
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@discourse/heic": "^1.0.0",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.4.0",
    "@jsquash/jpeg": "^1.6.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-aspect-ratio": "^1.1.10",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-context-menu": "^2.3.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-menubar": "^1.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@vercel/analytics": "^2.0.1",
    "ag-psd": "^31.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "dicom-parser": "^1.8.21",
    "gsap": "^3.15.0",
    "libraw-wasm": "^1.6.0",
    "lucide-react": "^1.23.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "paper": "^0.12.18",
    "parse-exr": "^1.0.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "utif2": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "next": {
      "postcss": "8.5.14"
    }
  }
}
