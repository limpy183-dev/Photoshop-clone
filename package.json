    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.62.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "next": {
      "postcss": "8.5.14"
    }
  }
