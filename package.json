    "@vercel/analytics": "1.6.1",
    "ag-psd": "^30.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "dicom-parser": "^1.8.21",
    "gsap": "^3.15.0",
    "libraw-wasm": "^1.1.2",
    "lucide-react": "^0.564.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "paper": "^0.12.18",
    "parse-exr": "^1.0.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^2.1.7",
    "sonner": "^1.7.1",
